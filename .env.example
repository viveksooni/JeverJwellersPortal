# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://jever_user:jever_pass@localhost:5432/jever_db

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOADS_DIR=./uploads
# Public base URL used in PDF invoice links and WhatsApp messages
PUBLIC_URL=http://localhost:3001

# ─── Shop (used in invoice PDF) ───────────────────────────────────────────────
SHOP_NAME=Jever Jwellers
SHOP_ADDRESS=123 Gold Street, Your City
SHOP_PHONE=+91-XXXXXXXXXX
SHOP_EMAIL=info@jwellers.com
SHOP_GSTIN=
